{
  "$schema": "https://json.schemastore.org/tsconfig",
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules/**/*",
    "test/**/*",
    "dist/**/*"
  ],
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "verbatimModuleSyntax": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmitOnError": true
  }
}
