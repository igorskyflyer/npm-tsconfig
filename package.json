{
    "name": "@igorskyflyer/{{pkg}}",
    "version": "{{version}}",
    "description": "{{desc}}",
    "sideEffects": false,
    "engines": {
        "node": ">=24.0"
    },
    "type": "module",
    "types": "./dist/index.d.ts",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "test": "vitest --run --passWithNoTests",
        "pub": "pnpm test && git push origin main --tags"
    },
    "keywords": [
        "{{tags}}",
        "igor dimitrijević",
        "igorskyflyer"
    ],
    "license": "MIT",
    "author": "Igor Dimitrijević <support@igorskyflyer.me> (https://github.com/igorskyflyer)",
    "funding": "https://ko-fi.com/igorskyflyer",
    "homepage": "https://github.com/igorskyflyer/{{repo}}",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/igorskyflyer/{{repo}}.git"
    },
    "bugs": {
        "url": "https://github.com/igorskyflyer/{{repo}}/issues"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.7",
        "@igorskyflyer/biome-config": "^2.2.0",
        "@types/node": "^24.12.0",
        "typescript": "^5.9.3",
        "vitest": "^4.1.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "packageManager": "pnpm@10.32.1"
}
