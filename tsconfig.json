{
    "include": ["src/**/*"],
    "exclude": ["node_modules/**/*", "test/**/*", "dist/**/*"],
    "compilerOptions": {
        "target": "ES2024",
        "lib": ["ES2024"],

        "module": "nodenext",
        "moduleResolution": "nodenext",

        "rootDir": "./src",
        "outDir": "./dist",

        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,

        "verbatimModuleSyntax": true,

        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitAny": true,
        "noImplicitReturns": true,

        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "noEmitOnError": true
    }
}
